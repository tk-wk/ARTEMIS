@page "/register"
@layout BlankLayout
@attribute [AllowAnonymous]
@inject HttpClient Http
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">

    <MudPaper Elevation="0" Style="background: linear-gradient(130deg, #000000, #1B5E20, #4CAF50); border-radius: 12px; padding: 1.5rem 2rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 1rem;">
        <MudIcon Icon="@Icons.Material.Filled.ShieldMoon" Style="font-size: 40px; color: #FFFFFF;" />
        <div>
            <MudText Typo="Typo.h6" Style="color: #FFFFFF; margin: 0;">Project Artemis</MudText>
            <MudText Typo="Typo.caption" Style="color: #FFFFFF;">Create your account to get started</MudText>
        </div>
    </MudPaper>

    @if (errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">@errorMessage</MudAlert>
    }

    <MudPaper Outlined Class="pa-6 mb-4" Style="border-radius: 12px;">
        <MudText font-size: 1rem; Class="mb-4 d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Outlined.Lock" Size="Size.Small" /> Account credentials
        </MudText>

        <MudTextField @bind-Value="username"
                      Label="Minecraft username"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Outlined.SportsEsports"
                      Class="mb-3" />

        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="password"
                              Label="Password"
                              Variant="Variant.Outlined"
                              InputType="@passwordInputType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@passwordIcon"
                              OnAdornmentClick="TogglePassword" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="confirmPassword"
                              Label="Confirm password"
                              Variant="Variant.Outlined"
                              InputType="@passwordInputType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@passwordIcon"
                              OnAdornmentClick="TogglePassword" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Outlined Class="pa-6 mb-4" Style="border-radius: 12px;">
        <MudText font-size: 1rem; Class="mb-4 d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" /> Tell us about you
        </MudText>

        <MudTextField @bind-Value="fullName"
                      Label="Full name"
                      Variant="Variant.Outlined"
                      Class="mb-3" />

        <MudTextField @bind-Value="facebookUrl"
                      Label="Facebook profile URL"
                      Variant="Variant.Outlined"
                      Placeholder="https://facebook.com/yourprofile"
                      Class="mb-3" />

        <MudSelect @bind-Value="school"
                   Label="School"
                   Variant="Variant.Outlined"
                   Class="mb-3">
            <MudSelectItem Value="@("University of the Philippines")">University of the Philippines</MudSelectItem>
            <MudSelectItem Value="@("Ateneo de Manila University")">Ateneo de Manila University</MudSelectItem>
            <MudSelectItem Value="@("De La Salle University")">De La Salle University</MudSelectItem>
            <MudSelectItem Value="@("University of Santo Tomas")">University of Santo Tomas</MudSelectItem>
            <MudSelectItem Value="@("Other")">Other</MudSelectItem>
        </MudSelect>

        <MudTextField @bind-Value="messageToAdmin"
                      Label="Message to admin"
                      Variant="Variant.Outlined"
                      Lines="3"
                      HelperText="Optional — anything you'd like us to know" />
    </MudPaper>

    <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Outlined.Info" Class="mb-4" Style="border-radius: 12px;">
        <MudText Typo="Typo.subtitle2" Class="mb-1">Why we collect this info</MudText>
        <MudText Typo="Typo.caption">
            Your Minecraft username identifies you in-game. Your full name and school help us verify
            you're part of the community. Your Facebook URL lets us reach you for announcements.
            None of your data is sold or shared with third parties — it's only used to manage
            Project Artemis membership.
        </MudText>
    </MudAlert>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               FullWidth
               Size="Size.Large"
               OnClick="HandleRegister"
               Disabled="loading"
               EndIcon="@Icons.Material.Filled.ArrowForward">
        @(loading ? "Creating account…" : "Create account")
    </MudButton>

    <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-3">
        Already have an account? <MudLink Href="/login">Sign in</MudLink>
    </MudText>

</MudContainer>

@code {
    string username = "", password = "", confirmPassword = "";
    string fullName = "", facebookUrl = "", school = "", messageToAdmin = "";
    bool loading = false;
    bool showPassword = false;
    string? errorMessage;

    InputType passwordInputType => showPassword ? InputType.Text : InputType.Password;
    string passwordIcon => showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    void TogglePassword() => showPassword = !showPassword;

    async Task HandleRegister()
    {
        errorMessage = null;

        if (password != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        loading = true;

        var response = await Http.PostAsJsonAsync("/api/v1/auth/register", new
        {
            username,
            password,
            fullName,
            facebookUrl,
            school,
            messageToAdmin
        });

        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/login?registered=true");
        }
        else
        {
            var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
            errorMessage = error?.Message ?? "Something went wrong.";
        }

        loading = false;
    }

    record ErrorResponse(string Message);
}