@page "/"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthProvider

@if (_claims.Any())
{
    <div style="position: fixed; bottom: 1rem; right: 1rem; background: #1e1e2d; border: 1px solid #33323e; border-radius: 8px; padding: 1rem; font-size: 12px; color: #b2b0bf; z-index: 9999; max-width: 300px;">
        <p style="color: #7e6fff; font-weight: 500; margin: 0 0 8px;">JWT Claims</p>
        @foreach (var claim in _claims)
        {
            <div style="display: flex; gap: 8px; margin-bottom: 4px;">
                <span style="color: #74718e; min-width: 80px;">@claim.Type.Split('/').Last()</span>
                <span>@claim.Value</span>
            </div>
        }
    </div>
} else
{
    <MudText>No claims.</MudText>
}

@code {
    private IEnumerable<System.Security.Claims.Claim> _claims = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        _claims = authState.User.Claims;
    }
}