@page "/"
@inject HttpClient Http
@inject IJSRuntime JS
@implements IDisposable
@inject JwtAuthStateProvider AuthProvider

<PageTitle>Dashboard</PageTitle>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudPaper Outlined Class="pa-4" Style="border-radius: 12px;">
            <MudText Typo="Typo.overline" Style="color: #74718e;">Whitelist status</MudText>

            @if (dashboard is null)
            {
                <MudSkeleton Height="80px" Class="mt-2" />
            }
            else
            {
                <div style="display: flex; align-items: center; gap: 12px; margin-top: 8px;">
                    <MudAvatar Style="@($"background: {StatusBackground}; color: {StatusColor}; border-radius: 10px;")" Size="Size.Large">
                        <MudIcon Icon="@StatusIcon" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6" Style="@($"color: {StatusColor}; margin: 0;")">@StatusLabel</MudText>
                        <MudText Typo="Typo.caption" Style="color: #74718e;">@StatusDescription</MudText>
                    </div>
                </div>

                <MudPaper Outlined Class="pa-3 mt-3" Style="background: #151521; border-radius: 8px; display: flex; align-items: center; gap: 8px;">
                    <MudIcon Icon="@Icons.Material.Outlined.Dns" Style="color: #74718e; font-size: 18px;" />
                    <MudText Typo="Typo.body2" Style="font-family: monospace; flex: 1; color: #b2b0bf;">play.artemissmp.net</MudText>
                    <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy"
                                   Size="Size.Small"
                                   Style="color: #7e6fff;"
                                   OnClick="CopyIp" />
                </MudPaper>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Outlined Class="pa-4" Style="border-radius: 12px;">
            <MudText Typo="Typo.overline" Style="color: #74718e;">Server status</MudText>

            @if (serverStatus is null)
            {
                <MudSkeleton Height="80px" Class="mt-2" />
            }
            else
            {
                <div style="display: flex; align-items: center; gap: 8px; margin: 8px 0 12px;">
                    <div style="@($"width: 8px; height: 8px; border-radius: 50%; background: {(serverStatus.Online ? "#3dcb6c" : "#ff3f5f")};")"></div>
                    <MudText Typo="Typo.body2" Style="@($"color: {(serverStatus.Online ? "#3dcb6c" : "#ff3f5f")}; font-weight: 500;")">
                        @(serverStatus.Online ? "Online" : "Offline")
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color: #74718e;">@serverStatus.Version</MudText>
                </div>

                <MudGrid Spacing="2">
                    <MudItem xs="4">
                        <MudPaper Outlined Class="pa-3" Style="background: #151521; text-align: center; border-radius: 8px;">
                            <MudText Typo="Typo.h5" Style="color: #3dcb6c;">@serverStatus.OnlinePlayers</MudText>
                            <MudText Typo="Typo.caption" Style="color: #74718e;">Online</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Outlined Class="pa-3" Style="background: #151521; text-align: center; border-radius: 8px;">
                            <MudText Typo="Typo.h5" Style="color: #b2b0bf;">@serverStatus.MaxPlayers</MudText>
                            <MudText Typo="Typo.caption" Style="color: #74718e;">Max slots</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Outlined Class="pa-3" Style="background: #151521; text-align: center; border-radius: 8px;">
                            <MudText Typo="Typo.h5" Style="color: #b2b0bf;">@serverStatus.Latency ms</MudText>
                            <MudText Typo="Typo.caption" Style="color: #74718e;">Ping</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.caption" Style="color: #74718e; font-family: monospace; margin-top: 8px; display: block;">
                    @serverStatus.Motd
                </MudText>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Outlined Class="pa-5" Style="border-radius: 12px; background: linear-gradient(135deg, #1a1a27 0%, #2a2840 100%); border-color: #534AB7; text-align: center;">
            <MudText Typo="Typo.overline" Style="color: #AFA9EC; letter-spacing: 0.1em;">🗓 Season 1 Launch</MudText>
            <MudText Typo="Typo.caption" Style="color: #74718e; display: block; margin-bottom: 1.5rem;">
                July 15, 2026 — The server opens its doors
            </MudText>

            <MudGrid Justify="Justify.Center" Spacing="2">
                <MudItem xs="3" sm="2">
                    <MudPaper Outlined Class="pa-3" Style="background: #1e1e2d; border-radius: 10px; border-color: #33323e;">
                        <MudText Style="font-size: 2rem; font-weight: 500; color: #CECBF6; line-height: 1; font-variant-numeric: tabular-nums;">
                            @days.ToString("D2")
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color: #74718e; text-transform: uppercase; letter-spacing: 0.08em;">Days</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="3" sm="2">
                    <MudPaper Outlined Class="pa-3" Style="background: #1e1e2d; border-radius: 10px; border-color: #33323e;">
                        <MudText Style="font-size: 2rem; font-weight: 500; color: #CECBF6; line-height: 1; font-variant-numeric: tabular-nums;">
                            @hours.ToString("D2")
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color: #74718e; text-transform: uppercase; letter-spacing: 0.08em;">Hours</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="3" sm="2">
                    <MudPaper Outlined Class="pa-3" Style="background: #1e1e2d; border-radius: 10px; border-color: #33323e;">
                        <MudText Style="font-size: 2rem; font-weight: 500; color: #CECBF6; line-height: 1; font-variant-numeric: tabular-nums;">
                            @minutes.ToString("D2")
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color: #74718e; text-transform: uppercase; letter-spacing: 0.08em;">Minutes</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="3" sm="2">
                    <MudPaper Outlined Class="pa-3" Style="background: #1e1e2d; border-radius: 10px; border-color: #33323e;">
                        <MudText Style="font-size: 2rem; font-weight: 500; color: #CECBF6; line-height: 1; font-variant-numeric: tabular-nums;">
                            @seconds.ToString("D2")
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color: #74718e; text-transform: uppercase; letter-spacing: 0.08em;">Seconds</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private DashboardDto? dashboard;
    private ServerStatusDto? serverStatus;
    private Timer? _timer;

    private static readonly DateTime LaunchDate = new DateTime(2026, 7, 15, 0, 0, 0, DateTimeKind.Utc);
    private int days, hours, minutes, seconds;

    protected override async Task OnInitializedAsync()
    {
        await AuthProvider.GetAuthenticationStateAsync();

        dashboard = await Http.GetFromJsonAsync<DashboardDto>("/api/v1/dashboard");

        // Mock server status — replace with mcsrvstat.us call
        serverStatus = new ServerStatusDto
        {
            Online = true,
            Version = "1.21.4 Java",
            OnlinePlayers = 12,
            MaxPlayers = 100,
            Latency = 24,
            Motd = "A Minecraft Server"
        };
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _timer = new Timer(_ =>
            {
                var diff = LaunchDate - DateTime.UtcNow;
                if (diff <= TimeSpan.Zero) diff = TimeSpan.Zero;

                days = (int)diff.TotalDays;
                hours = diff.Hours;
                minutes = diff.Minutes;
                seconds = diff.Seconds;

                InvokeAsync(StateHasChanged);
            }, null, 0, 1000);
        }
    }

    public void Dispose() => _timer?.Dispose();

    private async Task CopyIp() =>
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", "play.artemissmp.net");

    private string StatusLabel => dashboard?.Status switch
    {
        "Accepted" => "Whitelisted",
        "Pending" => "Pending review",
        "Rejected" => "Rejected",
        _ => "Unknown"
    };

    private string StatusDescription => dashboard?.Status switch
    {
        "Accepted" => "You have access to the server",
        "Pending" => "Your request is being reviewed",
        "Rejected" => "Your application was rejected",
        _ => ""
    };

    private string StatusColor => dashboard?.Status switch
    {
        "Accepted" => "#3dcb6c",
        "Pending" => "#ffb545",
        "Rejected" => "#ff3f5f",
        _ => "#74718e"
    };

    private string StatusBackground => dashboard?.Status switch
    {
        "Accepted" => "#0d2e1a",
        "Pending" => "#33290a",
        "Rejected" => "#2e0d0d",
        _ => "#1e1e2d"
    };

    private string StatusIcon => dashboard?.Status switch
    {
        "Accepted" => Icons.Material.Outlined.VerifiedUser,
        "Pending" => Icons.Material.Outlined.HourglassTop,
        "Rejected" => Icons.Material.Outlined.Block,
        _ => Icons.Material.Outlined.PersonOff
    };


    record ServerStatusDto
    {
        public bool Online { get; init; }
        public string Version { get; init; } = "";
        public int OnlinePlayers { get; init; }
        public int MaxPlayers { get; init; }
        public int Latency { get; init; }
        public string Motd { get; init; } = "";
    }
}